# manage volume
"changevolume 2%+ @DEFAULT_AUDIO_SINK@"
    XF86AudioRaiseVolume
"changevolume 2%- @DEFAULT_AUDIO_SINK@"
    XF86AudioLowerVolume
"changevolume toggle @DEFAULT_AUDIO_SINK@"
    XF86AudioMute
"changevolume toggle @DEFAULT_AUDIO_SOURCE@"
    XF86AudioMicMute

# manage media player
"playerctl next"
    XF86AudioNext
"playerctl previous"
    XF86AudioPrev
"playerctl play-pause"
    XF86AudioPlay

# manage monitor brightness
"changebrightness 5%+"
    XF86MonBrightnessUp
"changebrightness 5%-"
    XF86MonBrightnessDown

# set keyboard layout
"select_keyboard.sh"
    Mod4 + Shift + l

"rofi -show calc"
    XF86Calculator

# screenshots
"scrot -s - | xclip -selection clipboard -target image/png"
    Print

"scrot - | xclip -selection clipboard -target image/png"
    Shift + Print

# powermenu
"powermenu.sh"
    Mod4 + p
